# Google Gemini AI Configuration
GOOGLE_API_KEY=your_google_api_key_here
AI_MODEL_ID=models/gemini-flash-latest

# Firebase Configuration (Frontend)
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
FIREBASE_PROJECT_ID=your_firebase_project_id_here
FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
FIREBASE_APP_ID=your_app_id_here
FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=your_secret_key_here_change_this_in_production

# Poppler Path (for PDF to Image conversion)
POPPLER_PATH=C:\Users\pooja\OneDrive\Desktop\poppler\poppler-25.12.0\Library\bin

# CORS Configuration
CORS_ORIGINS=http://localhost:5000,https://yourdomain.com

# Upload/Storage Configuration
UPLOAD_FOLDER=uploads
VAULT_FOLDER=vault_storage
MAX_FILE_SIZE=50000000  # 50MB in bytes
